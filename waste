// Build All category
WORDS.All = [];
HINTS.All = {};
var allCats = Object.keys(WORDS);
for (var ac = 0; ac < allCats.length; ac++) {
  var cname = allCats[ac];
  if (cname === "All") continue;
  var arr = WORDS[cname];
  for (var aw = 0; aw < arr.length; aw++) {
    var w = arr[aw];
    WORDS.All.push(w);
    HINTS.All[w] = HINTS[cname][w];
  }
}

// ===================== STATE =====================
var players = [];
var currentCat = "Food";
var secretWord = "";
var secretHint = "";
var imposterIndices = [];
var aliveImposters = [];
var revealIdx = 0;
var timerInterval = null;
var timeLeft = 180;
var votes = {};
var scores = {crew:0, imp:0};
var numImposters = 1;
var hintsEnabled = false;
var currentGuesserIdx = -1;
var guessResults = [];

// ===================== INIT =====================
function init() {
  renderCats();
  renderPlayers();
  var inp = document.getElementById("inp-player");
  if (inp) {
    inp.addEventListener("keypress", function(e) {
      if (e.key === "Enter") addPlayer();
    });
  }
  var ginp = document.getElementById("inp-guess");
  if (ginp) {
    ginp.addEventListener("keypress", function(e) {
      if (e.key === "Enter") submitGuess();
    });
  }
}

function renderCats() {
  var g = document.getElementById("grid-cats");
  if (!g) return;
  g.innerHTML = "";
  var icons = {Food:"🍕", Animals:"🦁", Places:"🗽", Movies:"🎬", Objects:"📦", Nature:"🌲", Jobs:"💼", Sports:"⚽", All:"🎲"};
  var keys = Object.keys(WORDS);
  for (var i = 0; i < keys.length; i++) {
    var c = keys[i];
    var d = document.createElement("div");
    d.className = "cat-card" + (c === currentCat ? " selected" : "");
    d.innerHTML = '<div class="cat-icon">' + (icons[c] || "📁") + '</div><div class="cat-name">' + c + '</div><div class="cat-count">' + WORDS[c].length + ' words</div>';
    d.onclick = (function(cat) { return function() { currentCat = cat; renderCats(); }; })(c);
    g.appendChild(d);
  }
}

function addPlayer() {
  var inp = document.getElementById("inp-player");
  if (!inp) return;
  var name = inp.value.trim();
  if (!name) return;
  if (players.indexOf(name) !== -1) { alert("That name is already taken!"); return; }
  players.push(name);
  inp.value = "";
  renderPlayers();
}

function removePlayer(i) {
  players.splice(i, 1);
  renderPlayers();
}

function renderPlayers() {
  var list = document.getElementById("list-players");
  var countLbl = document.getElementById("lbl-count");
  var startBtn = document.getElementById("btn-start");
  if (!list) return;
  list.innerHTML = "";
  for (var i = 0; i < players.length; i++) {
    var p = players[i];
    var d = document.createElement("div");
    d.className = "player-item";
    d.innerHTML = '<div class="player-avatar">' + p.charAt(0).toUpperCase() + '</div><div class="player-name">' + p + '</div><button class="player-remove" onclick="removePlayer(' + i + ')">×</button>';
    list.appendChild(d);
  }
  var n = players.length;
  var minNeeded = numImposters === 1 ? 3 : 5;
  if (countLbl) {
    countLbl.textContent = n < minNeeded ? "Need " + (minNeeded - n) + " more for " + numImposters + " imposter" + (numImposters > 1 ? "s" : "") : n + " players ready";
  }
  if (startBtn) {
    startBtn.disabled = n < minNeeded;
  }
}

function setImposters(n) {
  numImposters = n;
  var btns = document.querySelectorAll("#seg-imposters .segment-btn");
  for (var i = 0; i < btns.length; i++) {
    btns[i].classList.toggle("active", i === (n - 1));
  }
  renderPlayers();
}

function toggleHints() {
  hintsEnabled = !hintsEnabled;
  var el = document.getElementById("tog-hints");
  if (el) el.classList.toggle("on", hintsEnabled);
}

// ===================== GAME FLOW =====================
function startGame() {
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  var pool = WORDS[currentCat];
  var idx = Math.floor(Math.random() * pool.length);
  secretWord = pool[idx];
  secretHint = HINTS[currentCat][secretWord] || "";

  imposterIndices = [];
  var available = [];
  for (var i = 0; i < players.length; i++) available.push(i);
  for (var j = 0; j < numImposters; j++) {
    var pick = Math.floor(Math.random() * available.length);
    imposterIndices.push(available.splice(pick, 1)[0]);
  }
  imposterIndices.sort(function(a,b){return a-b;});
  aliveImposters = imposterIndices.slice();

  revealIdx = 0;
  votes = {};
  guessResults = [];
  currentGuesserIdx = -1;

  show("scr-reveal");
  doReveal();
}

function doReveal() {
  var p = players[revealIdx];
  document.getElementById("rev-name").textContent = p;
  document.getElementById("cover").style.display = "flex";
  document.getElementById("btn-next").style.display = "none";
  document.getElementById("btn-begin").style.display = "none";

  var isImp = false;
  for (var i = 0; i < imposterIndices.length; i++) {
    if (imposterIndices[i] === revealIdx) { isImp = true; break; }
  }
  document.getElementById("s-label").textContent = isImp ? "YOU ARE THE" : "THE WORD IS";
  var sw = document.getElementById("s-word");
  sw.textContent = isImp ? "" : secretWord.toUpperCase();
  sw.style.display = isImp ? "none" : "block";
  var sr = document.getElementById("s-role");
  sr.textContent = isImp ? "IMPOSTER" : "CREWMATE";
  sr.className = "s-role " + (isImp ? "role-imposter" : "role-crew");

  var sh = document.getElementById("s-hint");
  if (isImp && hintsEnabled) {
    sh.innerHTML = '<strong style="color:var(--warning)">Hint:</strong> ' + secretHint;
  } else if (isImp) {
    sh.textContent = "You don't know the word. Listen to others and blend in! Try to figure it out from context.";
  } else {
    sh.textContent = "You know the word. Ask clever questions and watch for the Imposter who doesn't!";
  }
}

function uncover() {
  document.getElementById("cover").style.display = "none";
  if (revealIdx < players.length - 1) {
    document.getElementById("btn-next").style.display = "block";
  } else {
    document.getElementById("btn-begin").style.display = "block";
  }
}

function nextReveal() {
  revealIdx++;
  doReveal();
}

function beginDiscuss() {
  show("scr-discuss");
  document.getElementById("disc-cat").textContent = currentCat;
  startTimer(180);
}

function startTimer(sec) {
  timeLeft = sec;
  updateTimer();
  if (timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(function() {
    timeLeft--;
    updateTimer();
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      timerInterval = null;
      endDiscuss();
    }
  }, 1000);
}

function updateTimer() {
  var m = Math.floor(timeLeft / 60);
  var s = timeLeft % 60;
  var el = document.getElementById("timer");
  el.textContent = (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s;
  document.getElementById("tbar").style.width = (timeLeft / 180 * 100) + "%";
  el.classList.remove("warning", "danger");
  if (timeLeft <= 20) el.classList.add("danger");
  else if (timeLeft <= 60) el.classList.add("warning");
}

function endDiscuss() {
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  show("scr-vote");
  renderVote();
}

// ===================== VOTING =====================
function renderVote() {
  var g = document.getElementById("vote-grid");
  g.innerHTML = "";
  votes = {};
  for (var i = 0; i < players.length; i++) {
    var p = players[i];
    var d = document.createElement("div");
    d.className = "vote-card";
    d.dataset.idx = i;
    d.innerHTML = '<div class="vote-name">' + p + '</div><div class="vote-count">0 votes</div>';
    d.onclick = (function(idx) { return function() { castVote(idx); }; })(i);
    g.appendChild(d);
  }
  document.getElementById("vote-need").textContent = players.length;
  document.getElementById("vote-total").textContent = "0";
}

function castVote(idx) {
  votes[idx] = (votes[idx] || 0) + 1;
  updateVoteUI();
  var total = 0;
  var keys = Object.keys(votes);
  for (var i = 0; i < keys.length; i++) total += votes[keys[i]];
  document.getElementById("vote-total").textContent = total;
  if (total >= players.length) {
    setTimeout(resolveVote, 400);
  }
}

function updateVoteUI() {
  var cards = document.querySelectorAll(".vote-card");
  for (var i = 0; i < cards.length; i++) {
    var c = cards[i];
    var idx = parseInt(c.dataset.idx);
    var count = votes[idx] || 0;
    c.querySelector(".vote-count").textContent = count + " vote" + (count !== 1 ? "s" : "");
    if (count > 0) c.classList.add("selected"); else c.classList.remove("selected");
    var badge = c.querySelector(".vote-badge");
    if (count > 0) {
      if (!badge) {
        badge = document.createElement("div");
        badge.className = "vote-badge";
        c.appendChild(badge);
      }
      badge.textContent = count;
    } else if (badge) {
      badge.remove();
    }
  }
}

function resolveVote() {
  var max = -1;
  var winners = [];
  var keys = Object.keys(votes);
  for (var i = 0; i < keys.length; i++) {
    var k = keys[i];
    var idx = parseInt(k);
    var count = votes[k];
    if (count > max) { max = count; winners = [idx]; }
    else if (count === max) { winners.push(idx); }
  }

  if (winners.length !== 1) {
    alert("It's a tie! Resetting votes...");
    renderVote();
    return;
  }

  var winner = winners[0];
  var cards = document.querySelectorAll(".vote-card");
  for (var j = 0; j < cards.length; j++) {
    if (parseInt(cards[j].dataset.idx) === winner) cards[j].classList.add("eliminated");
  }

  setTimeout(function() {
    var wasImposter = false;
    for (var k = 0; k < aliveImposters.length; k++) {
      if (aliveImposters[k] === winner) { wasImposter = true; break; }
    }
    if (wasImposter) {
      var newAlive = [];
      for (var m = 0; m < aliveImposters.length; m++) {
        if (aliveImposters[m] !== winner) newAlive.push(aliveImposters[m]);
      }
      aliveImposters = newAlive;
      if (aliveImposters.length === 0) {
        showResult("crew-caught-all");
        return;
      }
    }
    showGuessScreen();
  }, 800);
}

// ===================== GUESS =====================
function showGuessScreen() {
  if (aliveImposters.length === 0) {
    showResult("crew-caught-all");
    return;
  }
  currentGuesserIdx = aliveImposters[0];
  document.getElementById("guess-name").textContent = players[currentGuesserIdx];
  show("scr-guess");
  document.getElementById("inp-guess").value = "";
  setTimeout(function() { document.getElementById("inp-guess").focus(); }, 100);
}

function submitGuess() {
  var guess = document.getElementById("inp-guess").value.trim();
  if (!guess) return;
  var correct = guess.toLowerCase() === secretWord.toLowerCase();

  guessResults.push({
    playerIdx: currentGuesserIdx,
    playerName: players[currentGuesserIdx],
    guess: guess,
    correct: correct
  });

  if (correct) {
    showResult("imposter-win");
  } else {
    var newAlive = [];
    for (var i = 0; i < aliveImposters.length; i++) {
      if (aliveImposters[i] !== currentGuesserIdx) newAlive.push(aliveImposters[i]);
    }
    aliveImposters = newAlive;
    if (aliveImposters.length > 0) {
      setTimeout(showGuessScreen, 300);
    } else {
      showResult("crew-win-guessed-wrong");
    }
  }
}

// ===================== RESULTS =====================
function showResult(resultType) {
  show("scr-result");
  var ban = document.getElementById("r-banner");
  var title = document.getElementById("r-title");
  var sub = document.getElementById("r-sub");
  var guessBox = document.getElementById("r-guess-box");
  var guessText = document.getElementById("r-guess-text");

  var impNamesArr = [];
  for (var i = 0; i < imposterIndices.length; i++) {
    impNamesArr.push(players[imposterIndices[i]]);
  }
  var impNames = impNamesArr.join(" & ");

  if (resultType === "crew-caught-all") {
    ban.className = "result-banner crew";
    title.textContent = "Crew Wins!";
    title.style.color = "var(--success)";
    sub.textContent = numImposters === 1 ? "The Imposter was caught!" : "All Imposters were caught!";
    scores.crew++;
    guessBox.style.display = "none";
    spawnConfetti("✅");
  }
  else if (resultType === "imposter-win") {
    ban.className = "result-banner imposter";
    title.textContent = "Imposter Wins!";
    title.style.color = "var(--imposter)";
    sub.textContent = impNames + " guessed correctly!";
    scores.imp++;
    guessBox.style.display = "block";
    var last = guessResults[guessResults.length - 1];
    guessText.innerHTML = '"' + last.guess + '"';
    guessText.style.color = "var(--imposter)";
    spawnConfetti("🔥");
  }
  else if (resultType === "crew-win-guessed-wrong") {
    ban.className = "result-banner crew";
    title.textContent = "Crew Wins!";
    title.style.color = "var(--success)";
    sub.textContent = "The Imposter guessed wrong!";
    scores.crew++;
    guessBox.style.display = "block";
    if (guessResults.length === 1) {
      guessText.innerHTML = '"' + guessResults[0].guess + '"';
    } else {
      var html = "";
      for (var g = 0; g < guessResults.length; g++) {
        html += '<div style="margin-bottom:4px">' + guessResults[g].playerName + ': "' + guessResults[g].guess + '"</div>';
      }
      guessText.innerHTML = html;
    }
    guessText.style.color = "var(--danger)";
    spawnConfetti("✅");
  }

  document.getElementById("r-word").textContent = secretWord;
  document.getElementById("r-imp").textContent = impNames;
  document.getElementById("r-imp-plural").textContent = numImposters > 1 ? "s" : "";
  document.getElementById("sc-crew").textContent = scores.crew;
  document.getElementById("sc-imp").textContent = scores.imp;
}

function spawnConfetti(emoji) {
  for (var i = 0; i < 24; i++) {
    setTimeout(function() {
      var el = document.createElement("div");
      el.className = "confetti";
      el.textContent = emoji;
      el.style.left = (10 + Math.random() * 80) + "vw";
      el.style.bottom = "-20px";
      el.style.animationDuration = (2 + Math.random() * 2) + "s";
      el.style.fontSize = (1.2 + Math.random()) + "rem";
      document.body.appendChild(el);
      setTimeout(function() { el.remove(); }, 4500);
    }, i * 80);
  }
}

function nextRound() {
  startGame();
}

function resetAll() {
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  players = [];
  scores = {crew:0, imp:0};
  renderPlayers();
  show("scr-setup");
}

function show(id) {
  var screens = document.querySelectorAll(".screen");
  for (var i = 0; i < screens.length; i++) {
    screens[i].classList.remove("active");
  }
  document.getElementById(id).classList.add("active");
}

init();
</script>
