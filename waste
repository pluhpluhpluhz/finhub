<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Imposter</title>
<style>
:root {
  --bg:#0a0a12; --surface:#151520; --surface-hover:#1e1e30;
  --border:rgba(255,255,255,0.06);
  --primary:#ff2e63; --primary-glow:rgba(255,46,99,0.25);
  --text:#f0f0f5; --text-dim:#7a7a8c;
  --success:#00d9a5; --warning:#ffc93c; --danger:#ff4757;
  --imposter:#ff6b81; --crew:#00d9c0;
}
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; touch-action:manipulation; }
html,body { height:100%; }
body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; background:var(--bg); color:var(--text); display:flex; justify-content:center; }
.app { width:100%; max-width:520px; min-height:100vh; padding:16px; display:flex; flex-direction:column; }

/* Fullscreen button - fixed top right */
.fs-btn {
  position:fixed; top:12px; right:12px; z-index:10000;
  width:44px; height:44px; border-radius:12px;
  background:var(--surface); border:1px solid var(--border);
  color:var(--text); font-size:1.3rem; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(0,0,0,0.4);
  transition:all 0.2s;
}
.fs-btn:active { transform:scale(0.9); background:var(--surface-hover); }

.header { text-align:center; padding:10px 0 24px; }
.logo { font-size:2.4rem; font-weight:900; letter-spacing:3px; background:linear-gradient(135deg,var(--primary),#ff8fab); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
.subtitle { color:var(--text-dim); font-size:0.8rem; letter-spacing:2px; text-transform:uppercase; margin-top:4px; }
.screen { display:none; flex-direction:column; flex:1; animation:fadeIn 0.3s ease; }
.screen.active { display:flex; }
@keyframes fadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
.card { background:var(--surface); border-radius:18px; padding:20px; margin-bottom:14px; border:1px solid var(--border); }
.card-title { font-size:0.95rem; font-weight:700; margin-bottom:12px; display:flex; align-items:center; gap:8px; }
input[type="text"] { width:100%; padding:14px 16px; border:2px solid var(--border); border-radius:12px; background:var(--bg); color:var(--text); font-size:1rem; outline:none; font-family:inherit; margin-bottom:10px; }
input[type="text"]:focus { border-color:var(--primary); box-shadow:0 0 0 3px var(--primary-glow); }
input::placeholder { color:#44445a; }
.btn { width:100%; padding:15px; border:none; border-radius:14px; font-size:0.95rem; font-weight:700; cursor:pointer; transition:transform 0.15s; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; font-family:inherit; }
.btn:active { transform:scale(0.97); }
.btn:disabled { opacity:0.35; cursor:not-allowed; transform:none !important; }
.btn-primary { background:linear-gradient(135deg,var(--primary),#c41e3a); color:white; box-shadow:0 4px 20px var(--primary-glow); }
.btn-secondary { background:var(--surface-hover); color:var(--text); border:1px solid var(--border); }
.btn-success { background:linear-gradient(135deg,var(--success),#00b894); color:var(--bg); }
.btn-ghost { background:transparent; color:var(--text-dim); border:1px solid var(--border); }
.toggle-row { display:flex; align-items:center; justify-content:space-between; padding:14px 0; border-bottom:1px solid var(--border); }
.toggle-row:last-child { border-bottom:none; }
.toggle-label { font-size:0.9rem; font-weight:600; }
.toggle-desc { font-size:0.75rem; color:var(--text-dim); margin-top:2px; }
.toggle-switch { position:relative; width:50px; height:28px; background:var(--bg); border-radius:14px; border:2px solid var(--border); cursor:pointer; transition:all 0.3s; flex-shrink:0; }
.toggle-switch.on { background:var(--primary); border-color:var(--primary); box-shadow:0 0 12px var(--primary-glow); }
.toggle-switch::after { content:''; position:absolute; top:3px; left:3px; width:18px; height:18px; background:white; border-radius:50%; transition:transform 0.3s; box-shadow:0 2px 6px rgba(0,0,0,0.3); }
.toggle-switch.on::after { transform:translateX(20px); }
.segmented { display:flex; background:var(--bg); border-radius:10px; padding:3px; border:1px solid var(--border); }
.segment-btn { flex:1; padding:9px; border:none; background:transparent; color:var(--text-dim); font-weight:700; font-size:0.85rem; border-radius:8px; cursor:pointer; transition:all 0.2s; font-family:inherit; }
.segment-btn.active { background:var(--surface-hover); color:var(--text); box-shadow:0 2px 8px rgba(0,0,0,0.2); }
.player-list { display:flex; flex-direction:column; gap:8px; margin:10px 0; max-height:220px; overflow-y:auto; }
.player-item { display:flex; align-items:center; gap:12px; padding:12px 14px; background:var(--bg); border-radius:12px; border:1px solid var(--border); }
.player-avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,var(--primary),#ff6b81); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.95rem; flex-shrink:0; }
.player-name { flex:1; font-weight:600; font-size:0.9rem; }
.player-remove { width:30px; height:30px; border:none; background:none; color:var(--danger); font-size:1.4rem; cursor:pointer; border-radius:6px; display:flex; align-items:center; justify-content:center; }
.cat-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; margin-bottom:4px; }
.cat-card { padding:16px 8px; background:var(--bg); border:2px solid var(--border); border-radius:14px; text-align:center; cursor:pointer; transition:all 0.2s; }
.cat-card:hover { transform:translateY(-2px); border-color:rgba(255,46,99,0.3); }
.cat-card.selected { border-color:var(--primary); background:rgba(255,46,99,0.06); }
.cat-icon { font-size:1.6rem; margin-bottom:4px; }
.cat-name { font-weight:700; font-size:0.8rem; }
.cat-count { font-size:0.65rem; color:var(--text-dim); margin-top:2px; }
.reveal-wrap { text-align:center; padding:10px 0 30px; flex:1; display:flex; flex-direction:column; justify-content:center; }
.pass-label { font-size:0.95rem; color:var(--text-dim); margin-bottom:4px; }
.pass-name { font-size:1.3rem; font-weight:800; margin-bottom:18px; }
.secret-card { background:linear-gradient(145deg,var(--surface),#1a1a30); border:2px solid var(--primary); border-radius:24px; padding:40px 24px; margin:0 0 20px; position:relative; min-height:240px; display:flex; flex-direction:column; align-items:center; justify-content:center; box-shadow:0 0 30px var(--primary-glow); }
.cover { position:absolute; inset:-2px; background:var(--bg); border-radius:24px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; z-index:10; border:2px solid var(--border); }
.cover:active { background:#0c0c14; }
.cover-icon { font-size:3rem; margin-bottom:10px; }
.cover-title { font-size:1.2rem; font-weight:800; margin-bottom:4px; }
.cover-hint { color:var(--text-dim); font-size:0.8rem; }
.s-label { font-size:0.7rem; text-transform:uppercase; letter-spacing:3px; color:var(--primary); margin-bottom:8px; font-weight:700; }
.s-word { font-size:2.2rem; font-weight:900; letter-spacing:1px; }
.s-role { font-size:1.5rem; font-weight:900; margin-top:4px; }
.s-hint { margin-top:14px; font-size:0.85rem; color:var(--text-dim); line-height:1.5; max-width:280px; }
.role-crew { color:var(--crew); }
.role-imposter { color:var(--imposter); }
.timer-box { text-align:center; margin:14px 0; }
.timer { font-size:3.5rem; font-weight:900; font-variant-numeric:tabular-nums; line-height:1; letter-spacing:2px; }
.timer.warning { color:var(--warning); animation:pulse 1s infinite; }
.timer.danger { color:var(--danger); animation:pulse 0.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.6} }
.timer-bar-wrap { width:100%; height:6px; background:var(--bg); border-radius:3px; margin-top:12px; overflow:hidden; border:1px solid var(--border); }
.timer-bar { height:100%; background:linear-gradient(90deg,var(--success),var(--warning),var(--danger)); border-radius:3px; transition:width 1s linear; }
.vote-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; margin:12px 0; }
.vote-card { padding:18px 8px; background:var(--bg); border:2px solid var(--border); border-radius:14px; text-align:center; cursor:pointer; transition:all 0.2s; position:relative; }
.vote-card:active { transform:scale(0.96); }
.vote-card.selected { border-color:var(--primary); background:rgba(255,46,99,0.08); }
.vote-card.eliminated { border-color:var(--danger); background:rgba(255,71,87,0.1); animation:shake 0.5s ease; }
@keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)} }
.vote-name { font-weight:800; font-size:1rem; margin-bottom:3px; }
.vote-count { font-size:0.75rem; color:var(--text-dim); }
.vote-badge { position:absolute; top:-5px; right:-5px; background:var(--primary); color:white; font-size:0.65rem; font-weight:800; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px var(--primary-glow); }
.result-banner { padding:28px 18px; border-radius:20px; text-align:center; margin-bottom:18px; }
.result-banner.crew { border:2px solid var(--success); background:rgba(0,217,165,0.06); }
.result-banner.imposter { border:2px solid var(--imposter); background:rgba(255,107,129,0.06); }
.result-title { font-size:1.6rem; font-weight:900; margin-bottom:6px; }
.result-sub { color:var(--text-dim); font-size:0.9rem; }
.score-board { display:flex; justify-content:space-around; margin:14px 0; padding:18px; background:var(--bg); border-radius:16px; border:1px solid var(--border); }
.score-item { text-align:center; }
.score-num { font-size:2rem; font-weight:900; }
.score-label { font-size:0.7rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:1px; margin-top:2px; font-weight:700; }
.info-pill { background:rgba(255,46,99,0.06); border-left:3px solid var(--primary); padding:12px 14px; border-radius:0 12px 12px 0; margin-bottom:14px; font-size:0.85rem; line-height:1.5; color:var(--text-dim); }
.info-pill strong { color:var(--text); }
.center { text-align:center; }
.dim { color:var(--text-dim); }
.confetti { position:fixed; pointer-events:none; z-index:9999; font-size:1.3rem; animation:confettiFall 2.5s ease-out forwards; }
@keyframes confettiFall { 0%{transform:translateY(0) rotate(0deg) scale(1); opacity:1} 100%{transform:translateY(-100vh) rotate(720deg) scale(0.5); opacity:0} }
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--surface-hover); border-radius:2px; }
@media(max-width:400px) { .logo{font-size:2rem} .timer{font-size:3rem} .s-word{font-size:1.8rem} .cat-grid,.vote-grid{grid-template-columns:1fr} }

/* Fullscreen styles */
:fullscreen .app { max-width:none; padding:24px; }
:fullscreen .fs-btn { top:20px; right:20px; }
:-webkit-full-screen .app { max-width:none; padding:24px; }
:-webkit-full-screen .fs-btn { top:20px; right:20px; }
:-moz-full-screen .app { max-width:none; padding:24px; }
:-moz-full-screen .fs-btn { top:20px; right:20px; }
</style>
<base target="_blank">
</head>
<body>

<button class="fs-btn" id="fs-btn" onclick="toggleFullscreen()" title="Toggle Fullscreen">⛶</button>

<div class="app">
  <div class="header">
    <div class="logo">IMPOSTER</div>
    <div class="subtitle">Social Deduction Party Game</div>
  </div>

  <div id="scr-setup" class="screen active">
    <div class="card">
      <div class="card-title">👥 Players <span class="dim" style="font-weight:400">(min 3)</span></div>
      <input type="text" id="inp-player" placeholder="Enter name and press +" maxlength="16">
      <button class="btn btn-secondary" onclick="addPlayer()">+ Add Player</button>
      <div id="list-players" class="player-list"></div>
      <div id="lbl-count" class="center dim" style="font-size:0.8rem; margin-top:4px"></div>
    </div>
    <div class="card">
      <div class="card-title">📂 Category</div>
      <div class="cat-grid" id="grid-cats"></div>
    </div>
    <div class="card">
      <div class="card-title">⚙️ Settings</div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label">Imposters</div>
          <div class="toggle-desc">How many imposters?</div>
        </div>
        <div class="segmented" id="seg-imposters">
          <button class="segment-btn active" onclick="setImposters(1)">1</button>
          <button class="segment-btn" onclick="setImposters(2)">2</button>
        </div>
      </div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label">Imposter Hints</div>
          <div class="toggle-desc">Give imposters a clue about the word</div>
        </div>
        <div class="toggle-switch" id="tog-hints" onclick="toggleHints()"></div>
      </div>
    </div>
    <button class="btn btn-primary" id="btn-start" onclick="startGame()" disabled>Start Game</button>
  </div>

  <div id="scr-reveal" class="screen">
    <div class="reveal-wrap">
      <div class="pass-label">📲 Pass the phone to</div>
      <div class="pass-name" id="rev-name">Player</div>
      <div class="secret-card">
        <div class="cover" id="cover" onclick="uncover()">
          <div class="cover-icon">🔒</div>
          <div class="cover-title">Tap to Reveal</div>
          <div class="cover-hint">Don't let anyone see!</div>
        </div>
        <div class="s-label" id="s-label">THE WORD IS</div>
        <div class="s-word" id="s-word">PIZZA</div>
        <div class="s-role" id="s-role"></div>
        <div class="s-hint" id="s-hint"></div>
      </div>
      <button class="btn btn-primary" id="btn-next" onclick="nextReveal()" style="display:none">Next Player →</button>
      <button class="btn btn-success" id="btn-begin" onclick="beginDiscuss()" style="display:none">Begin Discussion 🎉</button>
    </div>
  </div>

  <div id="scr-discuss" class="screen">
    <div class="card center">
      <div class="card-title" style="justify-content:center">💬 Discussion</div>
      <div class="info-pill">
        <strong style="color:var(--crew)">Crew:</strong> Ask about the word. Catch the Imposter!<br>
        <strong style="color:var(--imposter)">Imposter:</strong> Blend in. Figure out the word!
      </div>
      <div class="timer-box">
        <div class="timer" id="timer">03:00</div>
        <div class="timer-bar-wrap"><div class="timer-bar" id="tbar" style="width:100%"></div></div>
      </div>
      <div class="dim" style="font-size:0.8rem">Category: <strong id="disc-cat" style="color:var(--text)">Food</strong></div>
    </div>
    <button class="btn btn-primary" onclick="endDiscuss()">End Discussion & Vote</button>
  </div>

  <div id="scr-vote" class="screen">
    <div class="card">
      <div class="card-title center" style="justify-content:center">🗳️ Vote</div>
      <div class="info-pill center">Tap a name to vote. Pass the phone so everyone votes once.</div>
      <div class="vote-grid" id="vote-grid"></div>
      <div class="center dim" style="font-size:0.8rem; margin-top:6px">Votes: <strong id="vote-total" style="color:var(--text)">0</strong> / <span id="vote-need">0</span></div>
    </div>
  </div>

  <div id="scr-guess" class="screen">
    <div class="reveal-wrap">
      <div class="pass-label">📲 Pass the phone to</div>
      <div class="pass-name" id="guess-name" style="color:var(--imposter)">Imposter</div>
      <div class="card" style="margin:14px 0; width:100%">
        <div class="card-title center" style="justify-content:center">🕵️ Last Chance</div>
        <div class="center dim" style="font-size:0.85rem; line-height:1.5; margin-bottom:12px">The crew voted wrong!<br>Guess the secret word to steal the win.</div>
        <input type="text" id="inp-guess" placeholder="Type your guess..." maxlength="40" style="margin-bottom:12px">
        <button class="btn btn-primary" onclick="submitGuess()">Submit Guess</button>
      </div>
    </div>
  </div>

  <div id="scr-result" class="screen">
    <div id="r-banner" class="result-banner">
      <div class="result-title" id="r-title">Crew Wins!</div>
      <div class="result-sub" id="r-sub">The Imposter was caught</div>
    </div>
    <div class="card">
      <div class="card-title">🔍 The Reveal</div>
      <div class="center" style="margin-bottom:10px">
        <div class="dim" style="font-size:0.8rem; margin-bottom:3px">Secret word</div>
        <div style="font-size:1.8rem; font-weight:900; color:var(--crew)">"<span id="r-word">PIZZA</span>"</div>
      </div>
      <div class="center" style="margin-bottom:10px">
        <div class="dim" style="font-size:0.8rem; margin-bottom:3px">The Imposter<span id="r-imp-plural">s</span></div>
        <div style="font-size:1.1rem; font-weight:800; color:var(--imposter)" id="r-imp">Player</div>
      </div>
      <div id="r-guess-box" class="center" style="padding:12px; background:var(--bg); border-radius:12px; display:none; border:1px solid var(--border)">
        <div class="dim" style="font-size:0.8rem; margin-bottom:3px">Imposter's guess</div>
        <div style="font-size:1.1rem; font-weight:800" id="r-guess-text"></div>
      </div>
    </div>
    <div class="score-board">
      <div class="score-item">
        <div class="score-num" id="sc-crew" style="color:var(--crew)">0</div>
        <div class="score-label">Crew Wins</div>
      </div>
      <div class="score-item">
        <div class="score-num" id="sc-imp" style="color:var(--imposter)">0</div>
        <div class="score-label">Imposter Wins</div>
      </div>
    </div>
    <button class="btn btn-primary" onclick="nextRound()">Next Round →</button>
    <button class="btn btn-ghost" onclick="resetAll()">New Game</button>
  </div>
</div>

<script>
// ===================== FULLSCREEN =====================
function toggleFullscreen() {
  var doc = document;
  var btn = document.getElementById("fs-btn");
  if (!doc.fullscreenElement && !doc.webkitFullscreenElement && !doc.mozFullScreenElement && !doc.msFullscreenElement) {
    var el = document.documentElement;
    if (el.requestFullscreen) { el.requestFullscreen(); }
    else if (el.webkitRequestFullscreen) { el.webkitRequestFullscreen(); }
    else if (el.mozRequestFullScreen) { el.mozRequestFullScreen(); }
    else if (el.msRequestFullscreen) { el.msRequestFullscreen(); }
  } else {
    if (doc.exitFullscreen) { doc.exitFullscreen(); }
    else if (doc.webkitExitFullscreen) { doc.webkitExitFullscreen(); }
    else if (doc.mozCancelFullScreen) { doc.mozCancelFullScreen(); }
    else if (doc.msExitFullscreen) { doc.msExitFullscreen(); }
  }
}
function onFsChange() {
  var btn = document.getElementById("fs-btn");
  var doc = document;
  var isFs = !!(doc.fullscreenElement || doc.webkitFullscreenElement || doc.mozFullScreenElement || doc.msFullscreenElement);
  if (btn) btn.textContent = isFs ? "✕" : "⛶";
}
document.addEventListener("fullscreenchange", onFsChange);
document.addEventListener("webkitfullscreenchange", onFsChange);
document.addEventListener("mozfullscreenchange", onFsChange);
document.addEventListener("MSFullscreenChange", onFsChange);

